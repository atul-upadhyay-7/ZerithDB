{
  "framework": null,
  "buildCommand": "npm run build:edge",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "devCommand": "npm run dev:edge",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.edge.js"
    }
  ],
  "functions": {
    "dist/server.edge.js": {
      "runtime": "edge",
      "regions": ["iad1", "sfo1", "fra1", "sin1", "syd1"]
    }
  }
}