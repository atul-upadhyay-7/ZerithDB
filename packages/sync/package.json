{
  "name": "zerithdb-sync",
  "version": "0.2.0",
  "description": "Deterministic Sync Engine for ZerithDB",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "dexie": "^4.0.8",
    "lib0": "^0.2.98",
    "y-indexeddb": "^9.0.12",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.18",
    "zerithdb-core": "workspace:*",
    "zerithdb-db": "workspace:*",
    "zerithdb-network": "workspace:*",
    "zerithdb-utils": "workspace:*",
    "zerithdb-auth": "workspace:*"
  },
  "devDependencies": {
    "zerithdb-eslint-config": "workspace:*",
    "zerithdb-tsconfig": "workspace:*",
    "fake-indexeddb": "^6.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "files": [
    "dist",
    "src"
  ]
}
