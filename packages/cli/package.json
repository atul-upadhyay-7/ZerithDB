{
  "name": "zerithdb-cli",
  "version": "0.2.0",
  "description": "ZerithDB CLI — npx zerithdb init",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "zerithdb": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm",
    "dev": "tsup src/cli.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@prisma/internals": "^7.8.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.3.1",
    "ora": "^8.1.0",
    "prompts": "^2.4.2",
    "ws": "^8.18.0",
    "validate-npm-package-name": "^8.0.0",
    "ws": "^8.14.0",
    "zerithdb-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5",
    "zerithdb-eslint-config": "workspace:*",
    "zerithdb-tsconfig": "workspace:*"
  },
  "files": [
    "dist",
    "templates"
  ]
}
